{
  "name": "360-performance",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:admin": "pnpm --filter @360/admin dev",
    "dev:web": "pnpm --filter @360/web dev",
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit -p apps/admin/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json && tsc --noEmit -p packages/lib/tsconfig.json && tsc --noEmit -p packages/supabase/tsconfig.json",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "exceljs": "^4.4.0",
    "globals": "^17.7.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
