# Client config — Vite exposes ONLY VITE_*-prefixed vars to the browser bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WHATSAPP_NUMBER=923003600360
VITE_WHATSAPP_DISPLAY=+92 300 3600360

# Storefront (apps/web) ONLY — the public origin, e.g. https://360performance.pk
# REQUIRED for a production web build. WhatsApp/Facebook scrapers don't run JS and won't resolve a
# relative URL, so og:image/canonical must be absolute; the build-time prerender (and sitemap.xml)
# also needs it. Without it the prerender step skips and every shared product link previews as the
# generic homepage.
VITE_SITE_URL=

# Server / Edge Functions ONLY — never commit real values, never expose to a client.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
